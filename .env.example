# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_USE_REAL_AWS=false

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Chrome Extension Configuration
CHROME_EXTENSION_ID=your_extension_id_here
CHROME_CLIENT_ID=your_chrome_client_id_here
CHROME_CLIENT_SECRET=your_chrome_client_secret_here
CHROME_REFRESH_TOKEN=your_chrome_refresh_token_here

# Slack Integration
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# AWS Configuration
AWS_REGION=us-west-2

# Environment
NODE_ENV=development

# Publishing
PUBLISH_EXTENSION=false
ZIP_PATH=./dist.zip

# Devonn.AI Sandbox Environment Variables
# Copy this file to .env and customize as needed

# Application
APP_ENV=sandbox
DEBUG=true

# Database
POSTGRES_DB=devonn_ai
POSTGRES_USER=devonn
POSTGRES_PASSWORD=devonn_dev_password
DATABASE_URL=postgresql://devonn:devonn_dev_password@postgres:5432/devonn_ai

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=devonn_minio
MINIO_ROOT_PASSWORD=devonn_minio_password
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=devonn_minio
S3_SECRET_ACCESS_KEY=devonn_minio_password
S3_BUCKET_NAME=devonn-assets

# Mock AI Services
OPENAI_API_URL=http://mock-ai-service:8001
ELEVENLABS_API_URL=http://mock-tts-service:8002
STABILITY_API_URL=http://mock-image-gen:8003

# JWT Authentication
JWT_SECRET_KEY=dev_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# Feature Flags
ENABLE_MOCK_SERVICES=true
ENABLE_ENCRYPTION=true
